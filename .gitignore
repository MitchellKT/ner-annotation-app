# ───────────────────────── Python / backend ─────────────────────────
# Virtual environment — machine-specific, large. Recreate with `uv sync`.
backend/.venv/
.venv/
venv/

# Byte-compiled / cache
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ───────────────────────── Node / frontend ──────────────────────────
# Dependencies — recreate with `npm install`.
node_modules/

# Build output — recreate with `npm run build`.
frontend/dist/
dist/

# ───────────────────────── Runtime annotation data ──────────────────
# Corpora, annotations, per-user state and the shared tag / comment sidecars
# are user data, not source. Ignore every .json and .jsonl, then add back the
# few the repo genuinely needs.
*.json
*.jsonl

# The example corpus the quickstart in the README runs on.
!sample/input.jsonl

# Build configuration — needed to install and build the frontend.
!frontend/package.json
!frontend/package-lock.json
!frontend/tsconfig.json

# ───────────────────────── Editor / OS ──────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.log
